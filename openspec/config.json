{
  "project": "reloj",
  "stack": "Next.js 16.2.3 (App Router), React 19.2.4, TypeScript 5.x, Tailwind CSS 4.x, Supabase",
  "conventions": {
    "structure": "App Router con route groups (auth), (dashboard)",
    "pathAliases": "@/* -> ./src/*",
    "naming": "kebab-case",
    "linting": "eslint",
    "typeChecking": "tsc --strict"
  },
  "testing": {
    "strict_tdd": false,
    "strict_tdd_reason": "No test runner detected",
    "test_runner": null,
    "unit_tests": false,
    "integration_tests": false,
    "e2e_tests": false,
    "coverage": false,
    "quality_tools": {
      "linter": "eslint",
      "type_checker": "tsc --noEmit",
      "formatter": null
    }
  },
  "persistence": {
    "backend": "engram",
    "mode": "hybrid"
  }
}
