# =============================================================================
# SECURITY WARNING — NEVER COMMIT THIS FILE OR ITS CONTENTS
# =============================================================================
# This file is a TEMPLATE. Copy it to .env.local and fill in real values.
# NEVER commit .env.local, .env.production, or any file containing real credentials.
# Use .gitignore to exclude all .env* files except .env.example
# =============================================================================

# =============================================================================
# SUPABASE (Frontend / Next.js)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-public

# =============================================================================
# SUPABASE (Backend / Service Role)
# =============================================================================
# WARNING: Service role key has full database access. NEVER expose to frontend.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-secret

# =============================================================================
# CRON Authentication Token
# =============================================================================
# Token for authenticating scheduled/cron job requests to protected API endpoints
# Example: used in /api/check-connectivity to authorize health check calls
CRON_AUTH_TOKEN=your-secure-random-token-here

# =============================================================================
# AGENT BRIDGE — Device Connection Settings
# =============================================================================
# IP address of the biometric time clock device
DEVICE_IP=192.168.1.175

# Port for device connection (default: 443 for HTTPS)
DEVICE_PORT=443

# Device authentication credentials
# WARNING: These are stored encrypted in database, but DO NOT commit to git
DEVICE_USERNAME=admin
DEVICE_PASSWORD=your-device-password-here

# =============================================================================
# AGENT BRIDGE — Sync Intervals (milliseconds)
# =============================================================================
# How often to poll for events (default: 30000 = 30 seconds)
POLL_INTERVAL_MS=30000

# How often to send heartbeat to confirm device online (default: 60000 = 1 minute)
HEARTBEAT_INTERVAL_MS=60000

# How often to check door status (default: 10000 = 10 seconds)
DOOR_POLL_INTERVAL_MS=10000

# How often to check for pending commands (default: 2000 = 2 seconds)
COMMAND_POLL_INTERVAL_MS=2000

# =============================================================================
# AGENT BRIDGE — Logging
# =============================================================================
# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info
