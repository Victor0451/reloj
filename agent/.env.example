# Supabase Configuration
# Copy from the main project's .env.local or Supabase Dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Hikvision Device Configuration
DEVICE_IP=192.168.1.175
DEVICE_PORT=443
DEVICE_USERNAME=admin
DEVICE_PASSWORD=your-password

# =============================================================================
# DEVICE CREDENTIALS ENCRYPTION
# =============================================================================
# AES-256-GCM encryption for device passwords stored in database.
# Must match the same keys configured in the main application.
#
# Generate a 32-byte hex key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
DEVICE_CREDENTIAL_ACTIVE_KEY_ID=master-1
DEVICE_CREDENTIAL_KEYS_JSON={"master-1":"REPLACE_WITH_ACTUAL_KEY"}

# Agent Configuration
POLL_INTERVAL_MS=30000
HEARTBEAT_INTERVAL_MS=60000
DOOR_POLL_INTERVAL_MS=10000
COMMAND_POLL_INTERVAL_MS=2000
LOG_LEVEL=info
